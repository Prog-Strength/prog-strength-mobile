    "@babel/core": "^7.26.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/react": "~19.2.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
