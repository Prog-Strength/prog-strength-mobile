# Copy to .env.local and edit. EXPO_PUBLIC_* vars are inlined into the
# JS bundle at build time, so they cannot hold secrets — only public
# endpoint URLs that the app will hit from the user's phone.

# Backend API. The mobile app calls this directly for everything that
# isn't chat — workouts, exercises, progression, personal records.
EXPO_PUBLIC_API_URL=http://localhost:8080

# Agent. Only chat requests go here; the agent forwards tool calls to
# the API on the user's behalf using the JWT the app sends.
EXPO_PUBLIC_AGENT_URL=http://localhost:8001
