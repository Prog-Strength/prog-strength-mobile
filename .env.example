# Copy to .env.local. EXPO_PUBLIC_* vars are inlined into the JS
# bundle at build time, so they cannot hold secrets — only public
# endpoint URLs that the app will hit from the user's phone.
#
# Defaults below target the deployed Prog Strength backends so a
# fresh clone runs out of the box against live data. Switch either
# URL to http://localhost:<port> (or your Mac's LAN IP for a
# physical-device test) when you're iterating on a backend change
# end-to-end before deploy.

# Backend API. The mobile app calls this directly for everything
# that isn't chat — workouts, exercises, progression, personal
# records, nutrition, bodyweight.
EXPO_PUBLIC_API_URL=https://api.progstrength.fitness

# Agent. Only chat requests go here; the agent forwards tool calls
# back to the API on the user's behalf using the JWT the app sends.
EXPO_PUBLIC_AGENT_URL=https://agent.progstrength.fitness
